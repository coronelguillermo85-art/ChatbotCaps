            border-bottom: 3px solid #e63946;
            padding-bottom: 20px;
        }

        .header h1 {
            font-size: 2.2rem;
            color: #b91c2c;
            margin-bottom: 8px;
        }

        .header h2 {
            font-size: 1.2rem;
            font-weight: normal;
            color: #2c3e50;
        }

        .badge {
            background-color: #e63946;
            color: white;
            padding: 6px 14px;
